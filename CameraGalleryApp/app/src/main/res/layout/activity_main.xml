<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F0F"
    android:padding="4dp">

    <!-- Left Sidebar: Image Count -->
    <View
        android:id="@+id/left_sidebar_bg"
        android:layout_width="45dp"
        android:layout_height="match_parent"
        android:background="#1A1A1A"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/image_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:rotation="-90"
        android:text="GALLERY: 0"
        android:textColor="#888888"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/left_sidebar_bg"
        app:layout_constraintStart_toStartOf="@id/left_sidebar_bg"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Right Sidebar: Shutter Button -->
    <Button
        android:id="@+id/capture"
        android:layout_width="70dp"
        android:layout_height="match_parent"
        android:backgroundTint="#FF3B30"
        android:text="PHOTO"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:insetLeft="0dp"
        android:insetRight="0dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        app:cornerRadius="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Main Content: Grid -->
    <GridView
        android:id="@+id/grid"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="8dp"
        android:numColumns="2"
        android:verticalSpacing="12dp"
        android:horizontalSpacing="12dp"
        android:stretchMode="columnWidth"
        android:scrollbarStyle="outsideOverlay"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/capture"
        app:layout_constraintStart_toEndOf="@id/left_sidebar_bg"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>